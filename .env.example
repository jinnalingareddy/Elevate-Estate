# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset
NEXT_PUBLIC_CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Conekta
CONEKTA_PRIVATE_KEY=key_your_conekta_private_key
NEXT_PUBLIC_CONEKTA_PUBLIC_KEY=key_your_conekta_public_key
CONEKTA_WEBHOOK_SECRET=your_conekta_webhook_secret
# Conekta plan IDs — must match the plan IDs created in your Conekta dashboard
CONEKTA_PRO_PLAN_ID=plan_pro_mensual
CONEKTA_ELITE_PLAN_ID=plan_elite_mensual

# Subscription pricing (MXN pesos) — update in Vercel env vars; no redeploy needed
PRICE_PRO=799
PRICE_ELITE=1999
PRICE_PER_LISTING=299

# Listing limits per plan — update in Vercel env vars; no redeploy needed
LISTING_LIMIT_FREE=1
LISTING_LIMIT_PRO=10
LISTING_LIMIT_ELITE=50

# Resend
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://your_key@sentry.io/your_project_id
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=estateelevate
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# Security — generate with: openssl rand -hex 32
ROLE_COOKIE_SECRET=your_32_char_random_secret
# Vercel cron secret — set in Vercel dashboard, auto-injected into cron requests
CRON_SECRET=your_cron_secret

# App
NEXT_PUBLIC_APP_URL=https://yourdomain.com
